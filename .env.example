# Alpaca Bot — Environment Variables
# Copy this file to .env and fill in your keys:
#   cp .env.example .env
#
# Get your Alpaca API keys at: https://app.alpaca.markets/brokerage/new-account
# Paper trading is free — no real money required.

# Alpaca Trading API (required)
ALPACA_API_KEY=your_alpaca_api_key_here
ALPACA_SECRET_KEY=your_alpaca_secret_key_here

# Paper trading mode (set to "false" for live trading with real money)
ALPACA_PAPER=true
